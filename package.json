{
	"name": "merman",
	"version": "0.1.0",
	"type": "module",
	"description": "Mermaid-enhanced repository markdown editing web app",
	"scripts": {
		"dev": "NODE_ENV=development node --watch --env-file-if-exists=.env index.js",
		"start": "NODE_ENV=production node --env-file-if-exists=.env index.js",
		"build": "vite build",
		"preview": "npm run start",
		"lint:biome": "biome check .",
		"lint:html": "npm run build && npx w3c-html-validator dist/",
		"lint:otm": "otm-lint --check src",
		"lint": "npm run lint:biome && npm run lint:html && npm run lint:otm",
		"test": "node --test --env-file-if-exists=.env 'src/**/!(*.e2e).test.js' 'classes/**/*.test.js'",
		"test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=100 --test-coverage-exclude='**/*.test.js' --test-coverage-exclude='src/setup.js' --env-file-if-exists=.env 'src/**/!(*.e2e).test.js' 'classes/**/*.test.js'",
		"test:all": "npm run test && npm run test:coverage",
		"check": "npm run lint && npm run test:all"
	},
	"dependencies": {
		"@picocss/pico": "^2.0.6",
		"@possumtech/sqlrite": "git+https://github.com/possumtech/sqlrite.git",
		"better-auth": "latest",
		"express": "^4.19.2",
		"express-session": "^1.18.0",
		"on_the_money": "github:possumtech/on_the_money.js",
		"on_the_money.js": "git+https://github.com/possumtech/on_the_money.js.git",
		"ws": "^8.17.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.7.3",
		"@playwright/test": "^1.44.0",
		"css-tree": "3.1.0",
		"espree": "10.3.0",
		"linkedom": "0.18.6",
		"parse5": "7.2.1",
		"vite": "^5.2.11"
	}
}
