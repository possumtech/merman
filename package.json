{
  "name": "merman",
  "version": "0.1.0",
  "type": "module",
  "description": "Mermaid-enhanced repository markdown editing web app",
  "scripts": {
    "lint:biome": "biome check .",
    "lint:otm": "otm-lint .",
    "test": "node --test src/**/*.test.js classes/**/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage src/**/*.test.js classes/**/*.test.js",
    "check": "npm run lint:biome && npm run lint:otm && npm run test:coverage"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "ws": "^8.17.0",
    "better-auth": "latest",
    "sqlrite": "https://github.com/possumtech/sqlrite",
    "on_the_money": "https://github.com/possumtech/on_the_money.js"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "vite": "^5.2.11",
    "@playwright/test": "^1.44.0"
  }
}
