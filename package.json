{
  "name": "merman",
  "version": "0.1.0",
  "type": "module",
  "description": "Mermaid-enhanced repository markdown editing web app",
  "scripts": {
    "dev": "NODE_ENV=development node --env-file-if-exists=.env index.js",
    "start": "NODE_ENV=production node --env-file-if-exists=.env index.js",
    "build": "vite build",
    "preview": "npm run start",
    "lint:biome": "biome check .",
    "lint:otm": "otm-lint --check src",
    "test": "node --test --env-file-if-exists=.env src/**/*.test.js classes/**/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --env-file-if-exists=.env src/**/*.test.js classes/**/*.test.js",
    "check": "npm run lint:biome && npm run lint:otm && npm run test:coverage"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "ws": "^8.17.0",
    "better-auth": "latest",
    "@possumtech/sqlrite": "git+https://github.com/possumtech/sqlrite.git",
    "on_the_money.js": "git+https://github.com/possumtech/on_the_money.js.git",
    "@picocss/pico": "^2.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "css-tree": "3.1.0",
    "espree": "10.3.0",
    "linkedom": "0.18.6",
    "parse5": "7.2.1",
    "vite": "^5.2.11",
    "@playwright/test": "^1.44.0"
  }
}
